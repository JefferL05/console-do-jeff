# Upstash Redis (opcional para persistência real)
# Crie uma conta em https://upstash.com e adicione as variáveis abaixo:
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=Axxxxxxxxx

# Newsletter (Buttondown)
# Substitua pelo seu token do Buttondown:
# BUTTONDOWN_TOKEN=xxxxxxxx