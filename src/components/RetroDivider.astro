---
interface Props {
  type?: 'pixel' | 'title' | 'subtitle' | 'stars' | 'dotted' | 'comic-box' | 'neon-box' | 'tech-box' | 'action-box' | 'retro-box' | 'squad-box';
  text?: string;
}

const { type = 'pixel', text } = Astro.props;
---

{type === 'pixel' && (
  <div class="retro-divider retro-divider--pixel">
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span><span></span>
  </div>
)}

{type === 'title' && (
  <div class="retro-divider retro-divider--title">
    <span class="retro-divider__line"></span>
    <span class="retro-divider__icon">◆</span>
    <span class="retro-divider__line"></span>
  </div>
)}

{type === 'subtitle' && (
  <div class="retro-divider retro-divider--subtitle">
    <span class="retro-divider__square"></span>
    <span class="retro-divider__number">{text}</span>
    <span class="retro-divider__square"></span>
  </div>
)}

{type === 'stars' && (
  <div class="retro-divider retro-divider--stars">
    ★ ★ ★ ★ ★ ★ ★ ★
  </div>
)}

{type === 'dotted' && (
  <div class="retro-divider retro-divider--dotted">
    · · · · · · · · · · · · · · ·
  </div>
)}

{(type === 'comic-box' || type === 'neon-box' || type === 'tech-box' || type === 'action-box' || type === 'retro-box' || type === 'squad-box') && (
  <div class={`retro-box retro-box--${type}`}>
    <div class="retro-box__inner">
      <div class="retro-box__corner retro-box__corner--tl"></div>
      <div class="retro-box__corner retro-box__corner--tr"></div>
      <div class="retro-box__corner retro-box__corner--bl"></div>
      <div class="retro-box__corner retro-box__corner--br"></div>
      <div class="retro-box__content">
        {Astro.props.title && <div class="retro-box__title"><slot name="title" /></div>}
        {Astro.props.content && <div class="retro-box__text"><slot name="content" /></div>}
        <slot />
      </div>
    </div>
  </div>
)}

<style>
  .retro-divider {
    margin: 2.5rem 0;
    text-align: center;
  }

  /* Pixel divider */
  .retro-divider--pixel {
    display: flex;
    justify-content: center;
    gap: 6px;
    height: 16px;
    align-items: center;
  }

  .retro-divider--pixel span {
    display: block;
    width: 8px;
    height: 8px;
    background: linear-gradient(135deg, #4ecdc4, #45b7d1);
    animation: pixel-flicker 1.5s ease-in-out infinite;
  }

  .retro-divider--pixel span:nth-child(odd) {
    animation-delay: 0.1s;
    background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  }

  .retro-divider--pixel span:nth-child(3n) {
    background: linear-gradient(135deg, #ffd93d, #ff9500);
  }

  .retro-divider--pixel span:nth-child(4n) {
    background: linear-gradient(135deg, #6bcb77, #4ecdc4);
  }

  @keyframes pixel-flicker {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* Title divider */
  .retro-divider--title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .retro-divider__line {
    display: block;
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #4ecdc4, transparent);
  }

  .retro-divider__icon {
    font-size: 1.5rem;
    color: #4ecdc4;
    text-shadow: 0 0 10px #4ecdc4, 0 0 20px #4ecdc4;
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { 
      text-shadow: 0 0 10px #4ecdc4, 0 0 20px #4ecdc4;
      transform: scale(1);
    }
    50% { 
      text-shadow: 0 0 20px #4ecdc4, 0 0 40px #4ecdc4, 0 0 60px #4ecdc4;
      transform: scale(1.1);
    }
  }

  /* Subtitle divider */
  .retro-divider--subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .retro-divider__square {
    display: block;
    width: 12px;
    height: 12px;
    background: #ff6b6b;
    transform: rotate(45deg);
    animation: rotate-square 3s linear infinite;
  }

  .retro-divider__number {
    font-family: 'Courier New', monospace;
    font-size: 1.25rem;
    font-weight: bold;
    color: #fff;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border: 2px solid #4ecdc4;
    text-shadow: 0 0 10px #4ecdc4;
  }

  @keyframes rotate-square {
    from { transform: rotate(45deg); }
    to { transform: rotate(405deg); }
  }

  /* Stars divider */
  .retro-divider--stars {
    font-size: 0.75rem;
    letter-spacing: 0.5rem;
    color: #ffd93d;
    text-shadow: 0 0 10px #ff9500, 0 0 20px #ffd93d;
    animation: twinkle 1.5s ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Dotted divider */
  .retro-divider--dotted {
    font-size: 0.5rem;
    letter-spacing: 0.75rem;
    color: #666;
  }

  /* Retro Box - Sem Imagens */
  .retro-box {
    margin: 2rem 0;
    padding: 0 1rem;
  }

  .retro-box__inner {
    position: relative;
    padding: 1.5rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
    border: 3px solid;
    text-align: center;
  }

  .retro-box__corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 3px solid;
  }

  .retro-box__corner--tl {
    top: -3px;
    left: -3px;
    border-right: none;
    border-bottom: none;
    border-color: #4ecdc4;
  }

  .retro-box__corner--tr {
    top: -3px;
    right: -3px;
    border-left: none;
    border-bottom: none;
    border-color: #4ecdc4;
  }

  .retro-box__corner--bl {
    bottom: -3px;
    left: -3px;
    border-right: none;
    border-top: none;
    border-color: #4ecdc4;
  }

  .retro-box__corner--br {
    bottom: -3px;
    right: -3px;
    border-left: none;
    border-top: none;
    border-color: #4ecdc4;
  }

  .retro-box__title {
    font-family: 'Courier New', monospace;
    font-size: 1rem;
    font-weight: bold;
    color: #fff;
    letter-spacing: 3px;
    text-shadow: 0 0 10px currentColor, 0 0 20px currentColor;
    margin-bottom: 0.5rem;
  }

  .retro-box__text {
    font-size: 0.875rem;
    color: #a0aec0;
    letter-spacing: 1px;
  }

  /* Comic Box */
  .retro-box--comic-box .retro-box__inner {
    border-color: #ff6b6b;
    background: linear-gradient(135deg, #2d1f3d 0%, #1a1a2e 50%, #2d1f3d 100%);
  }

  .retro-box--comic-box .retro-box__title {
    color: #ff6b6b;
    text-shadow: 0 0 10px #ff6b6b, 0 0 20px #ff6b6b;
  }

  /* Neon Box */
  .retro-box--neon-box .retro-box__inner {
    border-color: #ff006e;
    background: linear-gradient(135deg, #1a0a1a 0%, #2d1f3d 50%, #1a0a1a 100%);
    animation: neon-pulse 2s ease-in-out infinite;
  }

  .retro-box--neon-box .retro-box__title {
    color: #ff006e;
    text-shadow: 0 0 10px #ff006e, 0 0 20px #8338ec, 0 0 30px #3a86ff;
  }

  @keyframes neon-pulse {
    0%, 100% { box-shadow: 0 0 10px rgba(255, 0, 110, 0.3); }
    50% { box-shadow: 0 0 25px rgba(255, 0, 110, 0.6); }
  }

  /* Tech Box */
  .retro-box--tech-box .retro-box__inner {
    border-color: #00ff88;
    background: linear-gradient(135deg, #0a1a1a 0%, #0f2d2d 50%, #0a1a1a 100%);
  }

  .retro-box--tech-box .retro-box__title {
    color: #00ff88;
    text-shadow: 0 0 10px #00ff88, 0 0 20px #00aaff;
  }

  /* Action Box */
  .retro-box--action-box .retro-box__inner {
    border-color: #ff4444;
    background: linear-gradient(135deg, #2d1a1a 0%, #3d1f1f 50%, #2d1a1a 100%);
    animation: action-pulse 1s ease-in-out infinite;
  }

  .retro-box--action-box .retro-box__title {
    color: #ff4444;
    text-shadow: 0 0 10px #ff4444, 0 0 20px #ff8800;
  }

  @keyframes action-pulse {
    0%, 100% { box-shadow: 0 0 10px rgba(255, 68, 68, 0.5); }
    50% { box-shadow: 0 0 30px rgba(255, 68, 68, 0.8); }
  }

  /* Retro Box */
  .retro-box--retro-box .retro-box__inner {
    border-color: #ffd700;
    background: linear-gradient(135deg, #2d2d1a 0%, #3d3d2d 50%, #2d2d1a 100%);
  }

  .retro-box--retro-box .retro-box__title {
    color: #ffd700;
    text-shadow: 0 0 10px #ffd700, 0 0 20px #ff6b6b;
  }

  /* Squad Box */
  .retro-box--squad-box .retro-box__inner {
    border-color: #4ecdc4;
    background: linear-gradient(135deg, #1a2d3d 0%, #16213e 50%, #1a2d3d 100%);
    padding: 1rem 1.5rem;
  }

  .retro-box--squad-box .retro-box__title {
    color: #4ecdc4;
    text-shadow: 0 0 10px #4ecdc4, 0 0 20px #4ecdc4;
    font-size: 1.25rem;
    letter-spacing: 5px;
  }

  .retro-box--squad-box .retro-box__text {
    color: #96ceb4;
    margin-top: 0.5rem;
  }

  /* Dark mode */
  :global(.dark) .retro-divider__line {
    background: linear-gradient(90deg, transparent, #4ecdc4, transparent);
  }

  :global(.dark) .retro-divider__number {
    background: linear-gradient(135deg, #0f0f1a, #1a1a2e);
  }

  :global(.dark) .retro-divider--dotted {
    color: #888;
  }

  :global(.dark) .retro-box__inner {
    background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%);
  }
</style>
