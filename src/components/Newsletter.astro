---
interface Props {
  placeholder?: string;
  buttonText?: string;
}

const { 
  placeholder = "Seu melhor email aqui...", 
  buttonText = "Inscrever-se" 
} = Astro.props;
---

<form 
  class="newsletter-form"
  action="https://buttondown.email/api/emails/embed-subscribe/console-do-jeff"
  method="POST"
  target="popupwindow"
>
  <label class="sr-only" for="newsletter-email">Email</label>
  
  <div class="newsletter-input-group">
    <input 
      id="newsletter-email"
      type="email" 
      name="email"
      placeholder={placeholder}
      required
      class="newsletter-input"
    />
    <button type="submit" class="newsletter-button">
      {buttonText}
    </button>
  </div>
  
  <p class="newsletter-note">
    Sem spam. Envio semanal de tips de desenvolvimento. Unsubscribe anytime.
  </p>
</form>

<style>
  .newsletter-form {
    margin: 2rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid #4ecdc4;
    border-radius: 8px;
  }
  
  .newsletter-input-group {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .newsletter-input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    background: #000;
    color: #0ff;
    border: 2px solid #4ecdc4;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 1rem;
  }
  
  .newsletter-input::placeholder {
    color: #666;
  }
  
  .newsletter-input:focus {
    outline: none;
    border-color: #0ff;
    box-shadow: 0 0 10px rgba(78, 205, 196, 0.3);
  }
  
  .newsletter-button {
    padding: 0.75rem 1.5rem;
    background: #4ecdc4;
    color: #000;
    border: 2px solid #4ecdc4;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .newsletter-button:hover {
    background: #0ff;
    box-shadow: 0 0 15px rgba(78, 205, 196, 0.5);
  }
  
  .newsletter-note {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: #888;
    text-align: center;
  }
  
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  
  :global(.dark) .newsletter-form {
    background: linear-gradient(135deg, rgba(15, 15, 26, 0.9), rgba(26, 26, 46, 0.9));
  }
  
  :global(.dark) .newsletter-input {
    background: #1a1a2e;
    color: #4ecdc4;
  }
</style>