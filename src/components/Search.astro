---
---

<div class="relative">
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <input
      type="text"
      id="search-input"
      placeholder="Pesquisar..."
      class="w-full sm:w-64 pl-10 pr-4 py-2 text-sm bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition-all"
    />
  </div>
  
  <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl max-h-96 overflow-y-auto z-50">
  </div>
</div>

<script>
  /**
   * Interface para os dados do post no índice de busca
   */
  interface Post {
    slug: string;
    title: string;
    description: string;
    category: string;
    tags: string[];
  }
  
  // Estado global da pesquisa
  let fuse: any = null;
  let posts: Post[] = [];
  let isSearchReady = false;
  
  /**
   * Carrega o índice de busca do servidor
   * Este JSON contém todos os posts para busca offline
   */
  async function loadPosts() {
    try {
      const response = await fetch('/search-index.json');
      if (!response.ok) {
        throw new Error('Falha ao carregar índice de busca');
      }
      posts = await response.json();
      
      // Inicializa Fuse.js após carregar os dados
      import('fuse.js').then(({ default: Fuse }) => {
        fuse = new Fuse(posts, {
          keys: ['title', 'description', 'category', 'tags'],
          threshold: 0.3,
          includeScore: true
        });
        isSearchReady = true;
      });
    } catch (e) {
      console.warn('Índice de busca não disponível');
      posts = [];
    }
  }
  
  /**
   * Escapa caracteres HTML para prevenir XSS
   * @param str - String a ser escapada
   */
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  
  /**
   * Renderiza os resultados da pesquisa
   * @param query - Termo de busca
   */
  function showResults(query: string) {
    const searchResults = document.getElementById('search-results');
    if (!searchResults || !fuse) return;
    
    const results = fuse.search(query).slice(0, 10);
    
    if (results.length === 0) {
      searchResults.innerHTML = `
        <div class="p-4 text-center text-gray-500 dark:text-gray-400">
          Nenhum resultado encontrado
        </div>
      `;
    } else {
      // Mapeia os resultados e escapa o HTML
      const html = results.map(({ item }: { item: Post }) => {
        // Escapa todos os dados antes de injetar
        const safeTitle = escapeHtml(item.title);
        const safeDesc = escapeHtml(item.description);
        const safeCategory = escapeHtml(item.category);
        const safeSlug = escapeHtml(item.slug);
        
        return `
          <a href="/blog/${safeSlug}" class="block p-4 hover:bg-gray-50 dark:hover:bg-gray-700 border-b border-gray-100 dark:border-gray-700 last:border-0 transition-colors">
            <div class="font-medium text-gray-900 dark:text-gray-100">${safeTitle}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">${safeDesc}</div>
            <div class="text-xs text-primary-600 dark:text-primary-400 mt-2 font-medium">${safeCategory}</div>
          </a>
        `;
      }).join('');
      
      searchResults.innerHTML = html;
    }
    
    searchResults.classList.remove('hidden');
  }
  
  // Elementos do DOM
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;
  
  // Carrega os posts ao focar no input
  searchInput?.addEventListener('focus', () => {
    if (posts.length === 0) loadPosts();
  });
  
  // Input: busca enquanto digita
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.trim();
    
    // Oculta resultados se query muito curta
    if (query.length < 2) {
      searchResults?.classList.add('hidden');
      return;
    }
    
    // Aguarda Fuse.js estar pronto
    if (!fuse && posts.length > 0) {
      loadPosts().then(() => showResults(query));
    } else if (fuse) {
      showResults(query);
    }
  });
  
  // Tecla Escape fecha os resultados
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchResults?.classList.add('hidden');
      searchInput.blur();
    }
  });
  
  // Clique fora fecha os resultados
  document.addEventListener('click', (e) => {
    if (!searchInput?.contains(e.target as Node) && 
        !searchResults?.contains(e.target as Node)) {
      searchResults?.classList.add('hidden');
    }
  });
</script>
