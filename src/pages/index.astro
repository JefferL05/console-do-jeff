---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const recentPosts = posts.slice(1, 7);

function formatDate(date: Date, options?: Intl.DateTimeFormatOptions) {
  return date.toLocaleDateString('pt-BR', {
    timeZone: 'America/Sao_Paulo',
    ...options
  });
}
---

<BaseLayout title="Console do Jeff | Blog Técnico">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        Console do Jeff
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Blog técnico focado em desenvolvimento de software, boas práticas e tecnologias modernas.
      </p>
    </div>
    
    {featuredPost && (
      <a href={`/blog/${featuredPost.slug}`} class="block mb-12 group">
        <article class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary-500 to-primary-700 p-8 sm:p-12">
          <div class="relative z-10">
            <span class="inline-block px-3 py-1 text-sm font-medium bg-white/20 text-white rounded-full mb-4">
              Artigo em destaque
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4 group-hover:underline decoration-2 underline-offset-4">
              {featuredPost.data.title}
            </h2>
            <p class="text-white/80 mb-6 max-w-2xl">
              {featuredPost.data.description}
            </p>
            <div class="flex items-center gap-4 text-white/90 text-sm">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                {formatDate(featuredPost.data.pubDate)}
              </span>
              <span>{featuredPost.data.author}</span>
            </div>
          </div>
        </article>
      </a>
    )}
    
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          Artigos Recentes
        </h2>
        <a href="/blog" class="flex items-center gap-1 text-primary-600 dark:text-primary-400 hover:underline">
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
      
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group">
            <article class="h-full bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg transition-shadow">
              {post.data.image && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.data.image.url}
                    alt={post.data.image.alt}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-3">
                  <span class="px-2 py-1 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 rounded text-xs font-medium">
                    {post.data.category}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    {formatDate(post.data.pubDate, { month: 'short', day: 'numeric' })}
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2">
                  {post.data.description}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
